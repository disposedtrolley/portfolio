{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PhotographyPortfolio",
  "type": "object",
  "required": ["meta", "projects"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "author"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "tagline": { "type": "string" },
        "avatar": { "type": "string", "description": "Path or URL to a portrait image used in the sidebar." },
        "bio": { "type": "string", "description": "Free-form Markdown rendered on the About page." },
        "contact": {
          "type": "object",
          "properties": {
            "email": { "type": "string", "format": "email" },
            "instagram": { "type": "string" },
            "website": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Project" }
    }
  },
  "additionalProperties": false,

  "definitions": {
    "Project": {
      "type": "object",
      "required": ["id", "title", "photos"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": { "type": "string" },
        "year": { "type": "integer" },
        "location": { "type": "string" },
        "background": {
          "type": "string",
          "description": "CSS color for the photo strip background.",
          "default": "#f5f2ee"
        },
        "story": {
          "type": "string",
          "description": "Free-form Markdown rendered in the bottom third of the viewport. Tells the story of the project. If omitted, photos fill the full height."
        },
        "photos": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Photo" }
        }
      },
      "additionalProperties": false
    },

    "Photo": {
      "type": "object",
      "required": ["id", "src"],
      "properties": {
        "id": { "type": "string" },
        "src": { "type": "string" },
        "alt": { "type": "string" },
        "flip": { "$ref": "#/definitions/FlipSide" }
      },
      "additionalProperties": false
    },

    "FlipSide": {
      "type": "object",
      "required": ["markdown"],
      "properties": {
        "markdown": {
          "type": "string",
          "description": "Markdown shown on the back of the photo when clicked."
        },
        "background": { "type": "string", "default": "#1c1c1c" },
        "textColor": { "type": "string", "default": "#f0ece4" }
      },
      "additionalProperties": false
    }
  }
}
